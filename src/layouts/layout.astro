---
import "../styles/global.css";
import { getLayoutData } from "#layouts/layout-data";
import { buildThemeCSS } from "#/lib/theme-css";
import { Theme } from "#/pods/theme/theme.model";
import type { LanguageCode } from "@content-island/api-client";
import HeaderPod from "#/pods/header/header.pod.astro";
import FooterPod from "#/pods/footer/footer.pod.astro";
import CookieBannerPod from "#/pods/cookie-banner/cookie-banner.pod.astro";

interface Props {
  lang: LanguageCode;
}

const { lang } = Astro.props;
const { theme, general, fonts } = await getLayoutData();
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {general?.favicon && <link rel="icon" href={general.favicon.url} />}
    {fonts.map((font) => (
      <link rel="stylesheet" href={font.url} />
    ))}
    {theme && <style set:html={buildThemeCSS(theme)} />}
    <script is:inline define:vars={{ darkTheme: Theme.Dark, lightTheme: Theme.Light }}>
      (() => {
        const storedTheme = localStorage.getItem("theme");
        const systemTheme = window.matchMedia("(prefers-color-scheme: light)").matches
          ? lightTheme
          : darkTheme;
        document.documentElement.dataset.theme = storedTheme ?? systemTheme;
      })();
    </script>
    <title>Event</title>
  </head>
  <body class="bg-base-100 text-base-content min-h-screen">
    <HeaderPod lang={lang} />
    <main>
      <slot />
    </main>
    <FooterPod lang={lang} />
    <CookieBannerPod lang={lang} />
  </body>
</html>
