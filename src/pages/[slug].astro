---
import { LANGUAGES } from "#/core/constants/language.constants";

export async function getStaticPaths() {
  return [
    { 
      params: { 
        slug: "privacy-policy" 
      } 
    },
    { 
      params: { 
        slug: "cookies" 
      } 
    },
  ];
}

const { slug } = Astro.params;
const defaultLang = LANGUAGES[0];
---

<meta http-equiv="refresh" content={`0;url=/${defaultLang}/${slug}`} />
