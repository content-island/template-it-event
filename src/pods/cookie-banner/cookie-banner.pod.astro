---
import { getCookieBanner } from "./api/cookie-banner.api";
import { mapCookieBanner } from "./cookie-banner.mapper";
import { getCookies } from "#/pods/cookies/api/cookies.api";

const [raw, cookiesPage] = await Promise.all([getCookieBanner(), getCookies()]);
if (!raw) return;

const banner = mapCookieBanner(raw);
const cookiesUrl = cookiesPage ? `/${cookiesPage.slug}` : "/cookies";
---

<div
  data-cookie-banner
  role="dialog"
  aria-live="polite"
  class="fixed bottom-6 left-6 z-50 max-w-sm w-[calc(100vw-3rem)] sm:w-sm
    bg-base-200 border border-base-300/60 rounded-2xl shadow-xl p-5
    flex flex-col gap-3 transition-all duration-300 hidden"
>
  <div>
    <h3 class="font-semibold text-base-content text-base mb-1">
      {banner.title}
    </h3>

    <p class="text-subtle text-sm leading-relaxed">
      {banner.description}

      <a
        href={cookiesUrl}
        class="underline underline-offset-2 hover:opacity-50 transition-colors ml-1"
      >
        {banner.learnMore}
      </a>
    </p>
  </div>

  <div class="flex gap-2">
    <button data-accept-all class="btn btn-primary btn-sm flex-1">
      {banner.acceptAll}
    </button>

    <button
      data-only-essential
      class="btn btn-ghost btn-sm flex-1 border border-base-300/60"
    >
      {banner.onlyEssential}
    </button>
  </div>
</div>

<script is:inline>
  (function () {
    const COOKIE_KEY = "cookie-consent";
    const banner = document.querySelector("[data-cookie-banner]");
    if (!banner) return;

    const consent = localStorage.getItem(COOKIE_KEY);

    if (consent === "all" || consent === "essential") {
      banner.remove();
      return;
    }

    banner.classList.remove("hidden");

    const acceptAll = banner.querySelector("[data-accept-all]");
    const essential = banner.querySelector("[data-only-essential]");

    function dismiss(value) {
      localStorage.setItem(COOKIE_KEY, value);

      banner.classList.add("opacity-0", "translate-y-4");

      setTimeout(() => {
        banner.remove();
      }, 300);
    }

    acceptAll?.addEventListener("click", () => dismiss("all"));
    essential?.addEventListener("click", () => dismiss("essential"));
  })();
</script>
