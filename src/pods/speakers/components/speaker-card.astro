---
import type { SpeakerItemModel } from "../speakers.model";
import SocialIcon from "#shared/components/social-icon.astro";
import { Calendar, MapPin } from "lucide-astro";

interface Props {
  speaker: SpeakerItemModel;
}
const { speaker } = Astro.props;
---
<div class="card-interactive p-6 text-center group h-full">
  {speaker.imageUrl && (
    <figure class="mb-5 flex justify-center">
      <div class="w-28 h-28 rounded-full overflow-hidden ring-2 ring-base-300/60 group-hover:ring-primary/30 transition-all duration-300 shrink-0">
        <img
          src={speaker.imageUrl}
          alt={speaker.imageName}
          class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
        />
      </div>
    </figure>
  )}
  <div class="flex flex-col justify-center items-center gap-2">
    <h3 class="text-base font-bold text-base-content">{speaker.name}</h3>
    <p class="text-primary font-medium text-sm light:text-primary-contrast">{speaker.jobTitle}</p>
    <div class="flex gap-2 justify-center items-center">
      <MapPin size={18} class="inline-block opacity-60" />
      <p class="text-subtle text-sm">{speaker.company}</p>
    </div>
    <hr class="w-24 my-2 border-t border-base-300" />
    <div class="flex gap-2 justify-center items-center">
      <Calendar size={18} class="inline-block opacity-60" />
      <p class="text-muted text-sm line-clamp-3 leading-relaxed">{speaker.description}</p>
    </div>
    {speaker.socialLinks.length > 0 && (
      <div class="flex flex-wrap gap-4 mt-4">
        {speaker.socialLinks.map((link) => (
          <a href={link.url} target="_blank" rel="noopener noreferrer"
            aria-label={link.tag}
            class="inline-flex text-subtle hover:text-primary transition-colors duration-200">
            <SocialIcon tag={link.tag} size={18} class="pointer-events-none" />
          </a>
        ))}
      </div>
    )}
  </div>
</div>
