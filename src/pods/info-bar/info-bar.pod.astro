---
import { getInfoBar } from "./api/info-bar.api";
import { mapInfoBar } from "./info-bar.mapper";
import MapPin from "lucide-astro/MapPin";
import AddToCalendarButton from "./components/add-to-calendar-button.astro";
import ShareButton from "./components/share-button.astro";

const raw = await getInfoBar();
if (!raw) return;
const infoBar = mapInfoBar(raw);
---
<div class="bg-base-300/50 border-b border-base-300/60 py-3 px-4 lg:px-8">
  <div class="max-w-6xl mx-auto flex flex-col items-center sm:flex-row sm:items-center sm:justify-between gap-4 sm:gap-3 text-sm">
    <div class="flex items-start gap-2">
      <MapPin size={16} class="text-secondary shrink-0 mt-0.5" />
      <div class="flex flex-col items-center sm:flex-row sm:items-center sm:gap-2">
        <strong class="text-base-content">{infoBar.venueName}</strong>
        <span class="text-subtle text-xs sm:text-sm">{infoBar.venueLocation}</span>
      </div>
    </div>
    <div class="flex items-center gap-2 shrink-0">
      <AddToCalendarButton href={infoBar.addToCalendarUrl} />
      <ShareButton url={infoBar.shareLinkUrl} />
    </div>
  </div>
</div>
