---
import Share2 from "lucide-astro/Share2";
import Check from "lucide-astro/Check";

interface Props {
  url: string;
}

const { url } = Astro.props;
---
<button
  id="share-btn"
  data-url={url}
  class="btn btn-xs btn-ghost text-subtle gap-1.5 transition-all duration-300 w-[5.5rem] justify-center"
>
  <span id="share-icon"><Share2 size={14} /></span>
  <span id="share-check" class="hidden"><Check size={14} /></span>
  <span id="share-label">Share</span>
</button>

<div id="share-toast" class="toast toast-end toast-bottom z-50 hidden">
  <div class="alert alert-success gap-2 text-sm py-2 px-4">
    <Check size={16} />
    <span>Link copied to clipboard!</span>
  </div>
</div>

<script>
  const btn = document.getElementById("share-btn");
  const toast = document.getElementById("share-toast");
  const icon = document.getElementById("share-icon");
  const check = document.getElementById("share-check");
  const label = document.getElementById("share-label");

  let resetTimer: ReturnType<typeof setTimeout> | null = null;

  btn?.addEventListener("click", async () => {
    const url = window.location.protocol + "//" + window.location.host + window.location.pathname + window.location.search + window.location.hash;

    await navigator.clipboard.writeText(url);

    btn.classList.add("btn-success", "text-success-content");
    btn.classList.remove("btn-ghost", "text-subtle");
    icon?.classList.add("hidden");
    check?.classList.remove("hidden");
    if (label) label.textContent = "Copied!";
    toast?.classList.remove("hidden");

    if (resetTimer) clearTimeout(resetTimer);
    resetTimer = setTimeout(() => {
      btn.classList.remove("btn-success", "text-success-content");
      btn.classList.add("btn-ghost", "text-subtle");
      icon?.classList.remove("hidden");
      check?.classList.add("hidden");
      if (label) label.textContent = "Share";
      toast?.classList.add("hidden");
    }, 2500);
  });
</script>
