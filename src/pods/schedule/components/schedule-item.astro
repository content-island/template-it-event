---
import type { ScheduleItemModel } from "../schedule.model";

interface Props {
  item: ScheduleItemModel;
}
const { item } = Astro.props;
---
<div class:list={[
  "flex gap-5 py-5 px-5 rounded-lg transition-all duration-300",
  item.highlighted
    ? "bg-primary/10 border-l-4 border-primary hover:bg-primary/20"
    : "border-l-4 border-base-300/40 hover:border-secondary/30 hover:bg-base-300/20"
]}>
  <div class="w-20 shrink-0 pt-0.5">
    <span class:list={["font-mono text-sm font-semibold", item.highlighted ? "text-primary" : "text-subtle"]}>
      {item.time}
    </span>
  </div>
  <div class="flex-1 min-w-0">
    <h3 class:list={["font-semibold text-base", item.highlighted ? "text-primary" : "text-base-content"]}>
      {item.title}
    </h3>
    {item.description && (
      <p class="text-muted text-sm mt-1 leading-relaxed">{item.description}</p>
    )}
  </div>
</div>
