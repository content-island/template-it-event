---
import { getFaqSection } from "./api/faq.api";
import { mapFaqSection } from "./faq.mapper";
import type { LanguageCode } from "@content-island/api-client";
import FAQItem from "./components/faq-item.astro";

interface Props {
  lang: LanguageCode;
}

const { lang } = Astro.props;
const raw = await getFaqSection(lang);
if (!raw) return;
const section = mapFaqSection(raw);
---
<section id="faq" class="section-padding bg-base-200/50">
  <div class="max-w-3xl mx-auto px-6">
    <div class="section-header">
      <h2 class="section-title md:text-5xl">{section.title}</h2>
      {section.description && (
        <p class="section-description max-w-2xl mx-auto">{section.description}</p>
      )}
    </div>
    <div class="flex flex-col gap-3">
      {section.items.map((item) => (
        <FAQItem item={item} />
      ))}
    </div>
  </div>
</section>
