---
import { getSponsorsSection } from "./api/sponsors.api";
import { mapSponsorsSection } from "./sponsors.mapper";
import SponsorLogo from "./components/sponsor-logo.astro";
import type { SponsorTier } from "./sponsors.model";

const raw = await getSponsorsSection();
if (!raw) return;
const section = mapSponsorsSection(raw);

const tiers: SponsorTier[] = ["Platinium", "Gold", "Silver"];

type TierConfig = {
  label: string;
  badgeClass: string;
  cardBorder: string;
  cardPadding: string;
  logoMaxH: string;
  cardWidth: string;
  maxWidth: string;
};

const tierConfig: Record<SponsorTier, TierConfig> = {
  Platinium: {
    label: "Platinum",
    badgeClass: "bg-primary/80 text-primary-content",
    cardBorder: "border-primary/30 hover:border-primary/70",
    cardPadding: "p-8",
    logoMaxH: "max-h-24",
    cardWidth: "w-72",
    maxWidth: "max-w-3xl",
  },
  Gold: {
    label: "Gold",
    badgeClass: "bg-secondary/50 text-secondary-content",
    cardBorder: "border-secondary/25 hover:border-secondary/60",
    cardPadding: "p-7",
    logoMaxH: "max-h-20",
    cardWidth: "w-64",
    maxWidth: "max-w-4xl",
  },
  Silver: {
    label: "Silver",
    badgeClass: "badge-ghost",
    cardBorder: "border-base-300/40 hover:border-base-content/25",
    cardPadding: "p-6",
    logoMaxH: "max-h-16",
    cardWidth: "w-52",
    maxWidth: "max-w-5xl",
  },
};

const sponsorsByTier = tiers.reduce((acc, tier) => {
  acc[tier] = section.sponsors.filter((s) => s.tier === tier);
  return acc;
}, {} as Record<SponsorTier, typeof section.sponsors>);
---
<section id="sponsors" class="section-padding px-6 bg-base-200/30">
  <div class="section-container">
    <div class="section-header">
      <h2 class="section-title md:text-5xl">{section.title}</h2>
      {section.description && (
        <p class="section-description max-w-2xl mx-auto">{section.description}</p>
      )}
    </div>

    {tiers.map((tier) => sponsorsByTier[tier].length > 0 && (
      <div class="mb-16 last:mb-0">
        <div class="flex items-center justify-center gap-3 mb-10">
          <div class="divider-fade"></div>
          <span class:list={["badge badge-sm p-2 px-4 rounded-md font-semibold uppercase tracking-widest", tierConfig[tier].badgeClass]}>
            {tierConfig[tier].label}
          </span>
          <div class="divider-fade"></div>
        </div>
        <div class:list={["flex flex-wrap justify-center gap-5 mx-auto", tierConfig[tier].maxWidth]}>
          {sponsorsByTier[tier].map((sponsor) => (
            <SponsorLogo
              sponsor={sponsor}
              cardBorder={tierConfig[tier].cardBorder}
              cardPadding={tierConfig[tier].cardPadding}
              logoMaxH={tierConfig[tier].logoMaxH}
              cardWidth={tierConfig[tier].cardWidth}
            />
          ))}
        </div>
      </div>
    ))}

    {section.ctaText && section.ctaUrl && (
      <div class="text-center mt-16">
        <a href={section.ctaUrl} class="btn btn-outline btn-primary">
          {section.ctaText}
        </a>
      </div>
    )}
  </div>
</section>
