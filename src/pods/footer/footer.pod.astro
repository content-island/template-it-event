---
import { getFooter } from "./api/footer.api";
import { mapFooter } from "./footer.mapper";
import { getPrivacyPolicy } from "#/pods/privacy-policy/api/privacy-policy.api";
import { getCookies } from "#/pods/cookies/api/cookies.api";
import SocialIcon from "#shared/components/social-icon.astro";

const [raw, privacyPolicy, cookies] = await Promise.all([getFooter(), getPrivacyPolicy(), getCookies()]);
const footer = raw ? mapFooter(raw) : { text: "", socialLinks: [] };
---
<footer class="bg-base-300/50 border-t border-base-300/40 py-8 px-6">
  <div class="max-w-4xl mx-auto flex flex-col gap-8">
    <div class="flex items-center justify-between">
      <div class="flex gap-6 text-sm">
        {privacyPolicy && (
          <a
            href={`/${privacyPolicy.slug}`}
            class="text-subtle hover:text-primary transition-colors duration-200 underline-offset-4 hover:underline"
          >
            Privacy Policy
          </a>
        )}
        {cookies && (
          <a
            href={`/${cookies.slug}`}
            class="text-subtle hover:text-primary transition-colors duration-200 underline-offset-4 hover:underline"
          >
            Cookies
          </a>
        )}
      </div>
      {footer.socialLinks.length > 0 && (
        <div class="flex items-center gap-4">
          {footer.socialLinks.map((link) => (
            <a
              href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={link.tag}
              class="inline-flex text-subtle hover:text-primary transition-colors duration-200"
            >
              <SocialIcon tag={link.tag} size={20} class="pointer-events-none" />
            </a>
          ))}
        </div>
      )}
    </div>
    <p class="text-center text-faint text-sm">{footer.text}</p>
  </div>
</footer>
