---
import { getStatsBar } from "./api/stats-bar.api";
import { mapStatsBar } from "./stats-bar.mapper";
import type { LanguageCode } from "@content-island/api-client";
import StatItem from "./components/stat-item.astro";

interface Props {
  lang: LanguageCode;
}

const { lang } = Astro.props;
const raw = await getStatsBar(lang);
if (!raw) return;
const statsBar = mapStatsBar(raw);
---
<section class="bg-base-200/60 py-14 border-y border-base-300/40">
  <div class="max-w-6xl mx-auto px-6">
    <div class="stats stats-vertical md:stats-horizontal gap-24 w-full shadow-none bg-transparent justify-center">
      {statsBar.stats.map((stat) => (
        <StatItem label={stat.label} value={stat.value} />
      ))}
    </div>
  </div>
</section>
